generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  emailVerified       DateTime?
  password            String
  image               String?
  profilePhoto        String?
  languagePreference  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  bookmarks           Bookmark[]
  communityPosts      CommunityPost[]
  creatorProfile      CreatorProfile?
  likes               Like[]
  passwordResetTokens PasswordResetToken[]
  savedDestinations   SavedDestination[]
  sessions            Session[]
  trips               Trip[]
  tripCopies          TripCopy[]
}

model Trip {
  id                String             @id @default(uuid())
  userId            String
  tripName          String
  description       String?
  startDate         DateTime
  endDate           DateTime
  coverPhoto        String?
  isPublic          Boolean            @default(false)
  shareToken        String?            @unique
  budgetLimit       Float?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  status            TripStatus         @default(upcoming)
  communityPosts    CommunityPost[]
  expenses          Expense[]
  notes             Note[]
  packingItems      PackingItem[]
  stops             Stop[]
  transportSegments TransportSegment[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripCopiesAsNew   TripCopy?          @relation("TripCopyNewTrip")

  @@index([userId])
}

model City {
  id              String             @id @default(uuid())
  name            String
  country         String
  region          String
  popularityScore Int
  costIndex       Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  activities      Activity[]
  savedBy         SavedDestination[]
  stops           Stop[]

  @@unique([name, country])
  @@index([country])
  @@index([region])
  @@index([popularityScore])
}

model Stop {
  id                 String             @id @default(uuid())
  tripId             String
  cityId             String
  cityName           String
  country            String
  arrivalDate        DateTime
  departureDate      DateTime
  stopOrder          Int
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  bookingReference   String?
  hotelAddress       String?
  hotelName          String?
  miscCost           Float?
  stayCost           Float?
  transportCost      Float?
  activities         Activity[]
  notes              Note[]
  city               City               @relation(fields: [cityId], references: [id])
  trip               Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  departingTransport TransportSegment[] @relation("TransportFrom")
  arrivingTransport  TransportSegment[] @relation("TransportTo")

  @@index([cityId])
  @@index([tripId, stopOrder])
}

model Activity {
  id            String   @id @default(uuid())
  cityId        String
  stopId        String?
  activityName  String
  description   String?
  activityType  String
  duration      Int
  cost          Float
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bestTime      String?
  rating        Float?
  scheduledDay  Int?
  scheduledTime String?
  city          City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stop          Stop?    @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([activityType])
  @@index([cityId])
  @@index([stopId])
}

model Expense {
  id        String          @id @default(uuid())
  tripId    String
  category  ExpenseCategory
  amount    Float
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
}

model PackingItem {
  id        String   @id @default(uuid())
  tripId    String
  itemName  String
  category  String
  isPacked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Note {
  id          String   @id @default(uuid())
  tripId      String
  stopId      String?
  noteContent String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stop        Stop?    @relation(fields: [stopId], references: [id])
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([stopId])
}

model SavedDestination {
  id        String   @id @default(uuid())
  userId    String
  cityId    String
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([cityId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TransportSegment {
  id            String    @id @default(uuid())
  tripId        String
  fromStopId    String
  toStopId      String
  mode          String
  departureTime DateTime?
  arrivalTime   DateTime?
  duration      Int?
  cost          Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fromStop      Stop      @relation("TransportFrom", fields: [fromStopId], references: [id])
  toStop        Stop      @relation("TransportTo", fields: [toStopId], references: [id])
  trip          Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model CreatorProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  bio         String?
  socialLinks Json?
  isVerified  Boolean @default(false)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id          String     @id @default(uuid())
  authorId    String
  tripId      String
  title       String
  description String?
  coverImage  String?
  tags        String[]
  publishedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookmarks   Bookmark[]
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip        Trip       @relation(fields: [tripId], references: [id])
  likes       Like[]
  copies      TripCopy[]

  @@index([authorId])
  @@index([tripId])
}

model Like {
  id        String        @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Bookmark {
  id        String        @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model TripCopy {
  id             String        @id @default(uuid())
  originalPostId String
  newTripId      String        @unique
  copiedById     String
  copiedAt       DateTime      @default(now())
  copiedBy       User          @relation(fields: [copiedById], references: [id], onDelete: Cascade)
  newTrip        Trip          @relation("TripCopyNewTrip", fields: [newTripId], references: [id], onDelete: Cascade)
  originalPost   CommunityPost @relation(fields: [originalPostId], references: [id], onDelete: Cascade)

  @@index([originalPostId])
  @@index([copiedById])
}

enum ExpenseCategory {
  transport
  stay
  activities
  meals
}

enum TripStatus {
  upcoming
  ongoing
  completed
}
